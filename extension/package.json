{
  "name": "dbterd-vscode",
  "displayName": "dbt ERD",
  "description": "Visualize your dbt project as an interactive ERD.",
  "version": "0.0.0",
  "publisher": "datnguye",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization", "Data Science"],
  "keywords": ["dbt", "erd", "data modeling", "dbterd", "visualization"],
  "icon": "icon.png",
  "bugs": {
    "url": "https://github.com/datnguye/dbterd-vscode/issues"
  },
  "homepage": "https://github.com/datnguye/dbterd-vscode#readme",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dbterd.openErd",
        "title": "dbt ERD: Open"
      },
      {
        "command": "dbterd.refresh",
        "title": "dbt ERD: Refresh"
      },
      {
        "command": "dbterd.reloadServer",
        "title": "dbt ERD: Reload Server"
      }
    ],
    "configuration": {
      "title": "dbterd",
      "properties": {
        "dbterd.dbtProjectPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the dbt project root (containing dbt_project.yml)."
        },
        "dbterd.serverPort": {
          "type": "number",
          "default": 0,
          "description": "Port for the dbterd server. 0 = auto-pick."
        },
        "dbterd.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Optional override for the base Python interpreter used to bootstrap the managed server venv. Leave empty to auto-detect (dbt project .venv → $VIRTUAL_ENV → python3 on PATH)."
        }
      }
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/datnguye/dbterd-vscode.git"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.js --production",
    "vscode:prepublish": "npm run package",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run compile && node esbuild.js --tests",
    "test": "node ./dist/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.25.0",
    "mocha": "^10.4.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.0"
  }
}
